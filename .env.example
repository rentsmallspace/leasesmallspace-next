# LeaseSmallSpace Next.js site env vars.
# Copy to .env.local and fill in values for local development.
# Production values live in Vercel project settings.

# === Supabase (existing) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Phase 2: Meta CAPI handler ===
# Server-only. URL of the deployed lss-ad-agency Edge Function.
# Format: https://<lss-ad-ops-project-ref>.supabase.co/functions/v1/capi-handler
LSS_CAPI_HANDLER_URL=

# === Optional ===
NEXT_PUBLIC_GSC_VERIFICATION=
